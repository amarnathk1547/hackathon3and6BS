        '\n' +
        '  // Fill email\n' +
        "  await page.fill('#contact', 'mail2kolla1547@gmail.com');\n" +
        '\n' +
        '  // Fill password\n' +
        "  await page.fill('#password', 'Medistack');\n" +
        '\n' +
        '  // Click login button\n' +
        `  await page.click('button[data-slot="button"]:has-text("Sign In")');\n` +
        '\n' +
        '  // Wait for network idle\n' +
        "  await page.waitForLoadState('networkidle');\n" +
        '\n' +
        '  // ✅ Wait for Logout button (this confirms login success)\n' +
        "  const logoutButton = page.getByRole('button', {\n" +
